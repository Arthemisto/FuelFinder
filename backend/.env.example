# FuelFinder backend environment example
# Copy this file to .env and choose one DATABASE_URL mode.
# Do not commit .env because it may contain real database credentials.

APP_NAME=FuelFinder API
APP_VERSION=1.0.0

# Common values:
# local          - default SQLite local/demo mode
# oracle-local   - Oracle Database running locally in Docker
# production     - deployed backend
ENVIRONMENT=local

# -------------------------------------------------------------------
# Database mode 1: SQLite local/demo database
# -------------------------------------------------------------------
# This mode stores the demo database in backend/data/fuelfinder.db.
DATABASE_URL=sqlite:///./data/fuelfinder.db

# -------------------------------------------------------------------
# Database mode 2: Oracle Database in Docker
# -------------------------------------------------------------------
# Tested with gvenzl/oracle-xe:21-slim exposed on localhost:1521.
# Typical service name for Oracle XE PDB is XEPDB1.
# Replace USER, PASSWORD, HOST, PORT, and SERVICE_NAME.
#
# Example:
# ENVIRONMENT=oracle-local
# DATABASE_URL=oracle+oracledb://USER:PASSWORD@HOST:PORT/?service_name=SERVICE_NAME
#
# Local Docker example:
# DATABASE_URL=oracle+oracledb://FUELFINDER:your_password@localhost:1521/?service_name=XEPDB1

# Frontend dev origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173