# FuelFinder Docker Compose environment example
# Copy this file to .env.compose and choose one database mode.
# Do not commit .env.compose because it contains real database credentials.

APP_NAME=FuelFinder API
APP_VERSION=1.0.0

# -------------------------------------------------------------------
# Mode 1: Oracle Autonomous Database with wallet
# -------------------------------------------------------------------
ENVIRONMENT=oracle-cloud-vm
DATABASE_URL=oracle+oracledb://FUELFINDER:your_db_password@fuelfinder_low

# Path inside the backend container.
ORACLE_WALLET_LOCATION=/opt/oracle/wallet
ORACLE_WALLET_PASSWORD=your_wallet_password

# Host path mounted into the backend container.
# Windows local example:
# ORACLE_WALLET_HOST_PATH=C:\Users\your_user\Downloads\Wallet_FUELFINDER
# OCI VM example:
ORACLE_WALLET_HOST_PATH=/home/opc/fuelfinder-wallet

# Local and deployed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,https://fuelfinder.duckdns.org

# -------------------------------------------------------------------
# Mode 2: local Oracle Docker database
# -------------------------------------------------------------------
# ENVIRONMENT=oracle-local-compose
# DATABASE_URL=oracle+oracledb://FUELFINDER:your_password@host.docker.internal:1521/?service_name=XEPDB1
# ORACLE_WALLET_LOCATION=
# ORACLE_WALLET_PASSWORD=
# ORACLE_WALLET_HOST_PATH=/tmp
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
